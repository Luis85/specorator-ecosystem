---
import Base from "@/layouts/Base.astro";
import MainContainer from "@/components/MainContainer.astro";
import { fetchEnrichedProjects } from "@/lib/fetchProjectData";
import { fetchEnrichedRoadmap } from "@/lib/fetchRoadmapData";
import { version as hubVersion } from "../../package.json";

const projects = await fetchEnrichedProjects();
const roadmap = await fetchEnrichedRoadmap(projects);
const activeMilestone =
  roadmap.find((r) => r.milestoneStatus === "active") ?? roadmap[0];

const layerColors: Record<string, string> = {
  ui: "#818cf8",
  runtime: "#22d3ee",
  agents: "#f472b6",
  workflow: "#fb923c",
};

const statusLabels: Record<string, string> = {
  "in-progress": "In Progress",
  planned: "Planned",
  done: "Done",
};

const statusColors: Record<string, string> = {
  "in-progress": "#22c55e",
  planned: "#f59e0b",
  done: "#3b82f6",
};

const specorator = projects.find((p) => p.id === "specorator");
const agenticWorkflow = projects.find((p) => p.id === "agentic-workflow");
const agentonomous = projects.find((p) => p.id === "agentonomous");
const specoratorRuntime = projects.find((p) => p.id === "specorator-runtime");

const builderEntryPoints = [
  {
    label: "agentic-workflow",
    description:
      "The raw 12-stage ADLC methodology — templates, quality gates, Claude Code agents — as a standalone CLI tool. No Obsidian required. Planned for MCP server exposure so any Claude Code session can pull in the full workflow engine with one config line.",
    cta: "Explore agentic-workflow",
    href: agenticWorkflow?.docs ?? agenticWorkflow?.repo ?? "#",
    color: layerColors.workflow,
    badge: "In Progress",
    badgeColor: "#22c55e",
    available: true,
  },
  {
    label: "agentonomous",
    description:
      "The TypeScript agent library. Six specialised roles (PM, Architect, Engineering, QA, Review, Writer) as composable building blocks for your own tooling, independent of the rest of the ecosystem.",
    cta: "View agentonomous",
    href: agentonomous?.docs ?? agentonomous?.repo ?? "#",
    color: layerColors.agents,
    badge: "Planned",
    badgeColor: "#f59e0b",
    available: false,
  },
  {
    label: "specorator-runtime",
    description:
      "The npm orchestration library and MCP server. Integrate the full agent lifecycle — session management, event streaming, stage gating — directly into your own application or Claude Code session.",
    cta: "View specorator-runtime",
    href: specoratorRuntime?.docs ?? specoratorRuntime?.repo ?? "#",
    color: layerColors.runtime,
    badge: "Planned",
    badgeColor: "#f59e0b",
    available: false,
  },
];
---

<Base
  title="Specorator — From Idea to Shipped Software, for Everyone"
  description="Specorator guides anyone — developer, PM, designer, or founder — through a structured 12-stage Agentic Development Lifecycle inside Obsidian. Claude Code agents handle spec drafting, task generation, and quality gates. You decide at every stage."
>
  <MainContainer>
    <!-- ─── Hero ──────────────────────────────────────────────────────── -->
    <section class="container-padding-x pt-20 pb-16 border-b border-border/10">
      <div class="flex flex-col gap-5 max-w-3xl">
        <!-- Eyebrow -->
        <div class="flex items-center gap-3 flex-wrap">
          <span class="font-mono text-xs text-gray uppercase tracking-widest">
            Obsidian Plugin · Claude Code · Open Source · No Coding Required
          </span>
          <span
            class="inline-flex items-center gap-1.5 font-mono text-xs text-green-400"
          >
            <span class="size-1.5 rounded-full bg-green-400 animate-pulse"
            ></span>
            active development
          </span>
          <span
            class="font-mono text-xs text-dark-gray border border-border/20 px-1.5 py-0.5 rounded"
          >
            hub v{hubVersion}
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="font-primary font-bold text-5xl md:text-6xl text-text tracking-tight leading-tight"
        >
          From idea to shipped software —<br />
          <span class="text-primary">with AI doing the heavy lifting</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-gray text-xl leading-relaxed max-w-2xl">
          Specorator is a plugin for <a
            href="https://obsidian.md"
            target="_blank"
            rel="noopener"
            class="text-text underline underline-offset-2 hover:text-primary transition-colors"
            >Obsidian</a
          > — a free, local-first notes app — that turns it into an extensible AI
          development platform. The built-in 12-stage workflow takes any idea to shipped
          software. Beyond that: manage agents, skills, commands, tools, and MCP servers;
          browse a plugin marketplace; extend the platform with your own additions.
          No coding required. Everything stays in plain files on your own computer.
        </p>

        <!-- CTAs -->
        <div class="flex items-center gap-4 pt-2 flex-wrap">
          <a
            href={specorator?.docs ??
              specorator?.repo ??
              "https://github.com/Luis85/specorator"}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 bg-primary text-body font-mono font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-primary/90 transition-colors duration-150 no-underline hover:no-underline"
          >
            Get the Plugin ↗
          </a>
          <a
            href="#use-cases"
            class="inline-flex items-center gap-2 border border-border/30 text-gray font-mono font-semibold text-sm px-5 py-2.5 rounded-xl hover:border-border/60 hover:text-text transition-colors duration-150 no-underline hover:no-underline"
          >
            Find your entry point ↓
          </a>
        </div>
      </div>
    </section>

    <!-- ─── Problem ───────────────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <div class="flex flex-col gap-10 max-w-3xl">
        <div class="flex flex-col gap-3">
          <h2
            class="font-mono text-xs uppercase tracking-widest text-gray flex items-center gap-3"
          >
            <span class="text-dark-gray">01</span>The Problem
          </h2>
          <p class="font-primary font-bold text-3xl text-text leading-snug">
            AI can write code.<br />
            <span class="text-dark-gray">It can't run your project.</span>
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          {
            [
              {
                icon: "⚡",
                heading: "Context gets lost",
                body: "AI tools are powerful in the moment but forget your project history, decisions, and rationale the instant the session ends.",
              },
              {
                icon: "🗂",
                heading: "Artifacts are scattered",
                body: "Specs live in Notion, tasks in Linear, notes in Slack threads. Nothing stays connected through the lifecycle of a feature.",
              },
              {
                icon: "🔁",
                heading: "No repeatable process",
                body: "There's no structured methodology. Each new project kicks off the same unstructured loop — from scratch, every time, for everyone.",
              },
            ].map((item) => (
              <div class="bg-card/50 border border-border/6 rounded-2xl p-5 flex flex-col gap-3">
                <span class="text-2xl">{item.icon}</span>
                <span class="font-mono font-semibold text-sm text-text">
                  {item.heading}
                </span>
                <p class="text-xs text-gray leading-relaxed">{item.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── How It Works ─────────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <div class="flex flex-col gap-10 max-w-3xl">
        <div class="flex flex-col gap-3">
          <h2
            class="font-mono text-xs uppercase tracking-widest text-gray flex items-center gap-3"
          >
            <span class="text-dark-gray">02</span>How It Works
          </h2>
          <p class="font-primary font-bold text-3xl text-text leading-snug">
            Three phases. Twelve stages. One repeatable process.
          </p>
        </div>

        <div class="flex flex-col gap-0">
          {
            [
              {
                step: "01",
                title: "Think & Plan",
                description:
                  "Describe your idea in plain language. PM and Architect agents help you articulate the problem, synthesise research, and produce a full specification — all saved as plain files in your project folder. You govern every decision; agents do the drafting.",
                detail:
                  "Stages 1–6: Idea → Research → Requirements → Design → Specification → Tasks",
              },
              {
                step: "02",
                title: "Build & Verify",
                description:
                  "Engineering and QA agents execute implementation and testing, reading your specs and writing results back as plain files. You receive plain-language summaries at each step and decide whether the output matches what you wanted before anything moves forward.",
                detail: "Stages 7–9: Implementation → Test Planning → Testing",
              },
              {
                step: "03",
                title: "Close & Learn",
                description:
                  "Writer agents draft release notes and retrospectives, closing the loop so your project folder reflects the finished work. Every project ends with a structured record — decisions logged, lessons captured, nothing lost.",
                detail: "Stages 10–12: Review → Release → Retrospective",
              },
            ].map((item, i) => (
              <div
                class={`flex gap-6 py-8 ${i < 2 ? "border-b border-border/10" : ""}`}
              >
                <div class="flex flex-col items-center gap-2 flex-shrink-0">
                  <span class="font-mono font-bold text-2xl text-primary">
                    {item.step}
                  </span>
                  {i < 2 && <div class="w-px flex-1 bg-border/20 min-h-8" />}
                </div>
                <div class="flex flex-col gap-2 pt-1">
                  <span class="font-primary font-bold text-xl text-text">
                    {item.title}
                  </span>
                  <p class="text-sm text-gray leading-relaxed">
                    {item.description}
                  </p>
                  <span class="font-mono text-[10px] text-dark-gray uppercase tracking-wide">
                    {item.detail}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── Use-Case Routing ──────────────────────────────────────────── -->
    <section
      id="use-cases"
      class="container-padding-x py-16 border-b border-border/10"
    >
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-3 max-w-3xl">
          <h2
            class="font-mono text-xs uppercase tracking-widest text-gray flex items-center gap-3"
          >
            <span class="text-dark-gray">03</span>Where to Start
          </h2>
          <p class="font-primary font-bold text-3xl text-text leading-snug">
            What brings you here?
          </p>
          <p class="text-gray text-base leading-relaxed">
            Most people should start with the plugin — it bundles everything.
            The individual components are there for developers who want to build
            their own tools on top.
          </p>
        </div>

        <!-- Primary: specorator plugin -->
        <div
          class="rounded-3xl border p-8 flex flex-col sm:flex-row gap-8 items-start"
          style={`border-color: ${layerColors.ui}; background: color-mix(in srgb, ${layerColors.ui} 6%, #111113); box-shadow: 0 0 40px -16px ${layerColors.ui}`}
        >
          <div class="flex flex-col gap-4 flex-1">
            <div class="flex items-center gap-3 flex-wrap">
              <span
                class="font-mono font-bold text-lg"
                style={`color: ${layerColors.ui}`}>specorator</span
              >
              <span
                class="font-mono text-[9px] font-bold uppercase tracking-wide border px-1.5 py-0.5 rounded"
                style={`color: #22c55e; border-color: #22c55e`}
              >
                Recommended starting point
              </span>
            </div>
            <p class="text-sm text-gray leading-relaxed max-w-xl">
              A plugin for Obsidian (a free notes app) that turns it into an
              extensible AI development platform. Install it once and you get
              the 12-stage workflow, AI agents, and structured templates out of
              the box. Beyond that: manage skills, commands, tools, and MCP
              servers from one interface; browse a plugin marketplace; extend
              the platform with your own additions. Works for anyone — product
              managers, designers, founders, developers. No coding required.
            </p>
            <a
              href={specorator?.docs ??
                specorator?.repo ??
                "https://github.com/Luis85/specorator"}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 bg-primary text-body font-mono font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-primary/90 transition-colors duration-150 no-underline hover:no-underline self-start"
            >
              Get the Plugin ↗
            </a>
          </div>
          <div
            class="flex flex-col gap-2 flex-shrink-0 font-mono text-xs text-gray border border-border/10 rounded-2xl p-4 bg-body/40 min-w-44"
          >
            <span class="text-dark-gray uppercase tracking-widest text-[9px]"
              >Includes</span
            >
            <span class="flex items-center gap-2"
              ><span
                class="size-1.5 rounded-full"
                style={`background: ${layerColors.workflow}`}
              ></span>agentic-workflow</span
            >
            <span class="flex items-center gap-2"
              ><span
                class="size-1.5 rounded-full"
                style={`background: ${layerColors.agents}`}></span>agentonomous <span
                class="text-dark-gray">(v2.0)</span
              ></span
            >
            <span class="flex items-center gap-2"
              ><span
                class="size-1.5 rounded-full"
                style={`background: ${layerColors.runtime}`}
              ></span>specorator-runtime <span class="text-dark-gray"
                >(v2.0)</span
              ></span
            >
            <div
              class="mt-1 pt-2 border-t border-border/10 flex flex-col gap-1.5"
            >
              <span class="text-dark-gray uppercase tracking-widest text-[9px]"
                >Planned</span
              >
              <span class="flex items-center gap-2"
                ><span class="size-1.5 rounded-full bg-primary/50"></span>MCP
                server</span
              >
            </div>
          </div>
        </div>

        <!-- Builder divider -->
        <div class="flex items-center gap-4">
          <div class="flex-1 h-px bg-border/10"></div>
          <span
            class="font-mono text-xs text-dark-gray uppercase tracking-widest"
            >For builders — want to go deeper?</span
          >
          <div class="flex-1 h-px bg-border/10"></div>
        </div>

        <!-- Secondary: individual components for technical users -->
        <div class="grid md:grid-cols-3 gap-4">
          {
            builderEntryPoints.map((ep) => (
              <div
                class="bg-card/70 border border-border/6 rounded-3xl p-6 flex flex-col gap-4 relative overflow-hidden"
                style={`border-top: 2px solid ${ep.color}`}
              >
                <div class="flex items-start justify-between gap-2">
                  <span
                    class="font-mono font-semibold text-sm leading-snug"
                    style={`color: ${ep.color}`}
                  >
                    {ep.label}
                  </span>
                  <span
                    class="font-mono text-[9px] font-bold uppercase tracking-wide border px-1.5 py-0.5 rounded flex-shrink-0"
                    style={`color: ${ep.badgeColor}; border-color: ${ep.badgeColor}`}
                  >
                    {ep.badge}
                  </span>
                </div>
                <p class="text-xs text-gray leading-relaxed flex-1">
                  {ep.description}
                </p>
                {ep.available ? (
                  <a
                    href={ep.href}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 font-mono text-xs font-semibold opacity-80 hover:opacity-100 transition-colors duration-150 no-underline hover:no-underline"
                    style={`color: ${ep.color}`}
                  >
                    {ep.cta} ↗
                  </a>
                ) : (
                  <span
                    class="inline-flex items-center gap-1.5 font-mono text-xs font-semibold opacity-40 cursor-not-allowed"
                    aria-disabled="true"
                    style={`color: ${ep.color}`}
                  >
                    {ep.cta} ↗
                  </span>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── 04 Architecture ──────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-3 max-w-3xl">
          <h2
            class="font-mono text-xs uppercase tracking-widest text-gray flex items-center gap-3"
          >
            <span class="text-dark-gray">04</span>Architecture
          </h2>
          <p class="font-primary font-bold text-2xl text-text leading-snug">
            Four components. One composable system.
          </p>
          <p class="text-gray text-sm leading-relaxed max-w-xl">
            Each layer has a single responsibility. The specorator plugin is the
            primary entry point — it bundles the workflow, agents, and runtime
            into a ready-to-use interface that requires no technical setup. The
            three underlying components are independently usable for developers
            who want to build their own tools on top of the same foundation.
            User decisions drive every stage; agents never advance the workflow
            autonomously.
          </p>
        </div>

        <div class="flex flex-col items-start max-w-xl gap-0">
          <!-- Row 1: specorator -->
          <div
            class="w-full rounded-2xl border p-4 flex flex-col gap-1 transition-shadow duration-200 hover:shadow-lg"
            style={`border-color: ${layerColors.ui}; background: color-mix(in srgb, ${layerColors.ui} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.ui}`}
          >
            <div class="flex items-center justify-between gap-2">
              <span
                class="font-mono font-semibold text-sm"
                style={`color: ${layerColors.ui}`}>specorator</span
              >
              <span class="size-2 rounded-full bg-green-400" title="In Progress"
              ></span>
            </div>
            <span class="text-xs text-gray"
              >UI / Visualization Layer · Extensible Platform</span
            >
          </div>

          <div class="flex flex-col items-center py-1 gap-0.5 self-center">
            <span class="font-mono text-[10px] text-dark-gray"
              >spec methodology</span
            >
            <div class="w-px h-4 bg-border/30"></div>
            <span class="text-dark-gray text-[8px]">▼</span>
          </div>

          <!-- Row 2: specorator-runtime -->
          <div
            class="w-full rounded-2xl border border-dashed p-4 flex flex-col gap-1 opacity-70 transition-shadow duration-200 hover:shadow-lg"
            style={`border-color: ${layerColors.runtime}; background: color-mix(in srgb, ${layerColors.runtime} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.runtime}`}
          >
            <div class="flex items-center justify-between gap-2">
              <span
                class="font-mono font-semibold text-sm"
                style={`color: ${layerColors.runtime}`}>specorator-runtime</span
              >
              <span
                class="font-mono text-[9px] font-bold uppercase tracking-wide text-amber-400 border border-amber-400 px-1.5 py-0.5 rounded"
                >planned</span
              >
            </div>
            <span class="text-xs text-gray"
              >Execution Runtime · Orchestration Bridge</span
            >
          </div>

          <!-- Split connector -->
          <div class="flex justify-around w-full max-w-xl px-16 py-1">
            <div class="flex flex-col items-center gap-0.5">
              <div class="w-px h-4 bg-border/30"></div>
              <span class="text-dark-gray text-[8px]">▼</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <div class="w-px h-4 bg-border/30"></div>
              <span class="text-dark-gray text-[8px]">▼</span>
            </div>
          </div>

          <!-- Row 3: agentonomous + agentic-workflow -->
          <div class="w-full grid grid-cols-2 gap-4">
            <div
              class="rounded-2xl border border-dashed p-4 flex flex-col gap-1 opacity-70 transition-shadow duration-200 hover:shadow-lg"
              style={`border-color: ${layerColors.agents}; background: color-mix(in srgb, ${layerColors.agents} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.agents}`}
            >
              <div class="flex items-center justify-between gap-2">
                <span
                  class="font-mono font-semibold text-sm"
                  style={`color: ${layerColors.agents}`}>agentonomous</span
                >
                <span
                  class="font-mono text-[9px] font-bold uppercase tracking-wide text-amber-400 border border-amber-400 px-1.5 py-0.5 rounded"
                  >planned</span
                >
              </div>
              <span class="text-xs text-gray"
                >Agent Library · 6 Specialized Roles</span
              >
            </div>

            <div
              class="rounded-2xl border p-4 flex flex-col gap-1 transition-shadow duration-200 hover:shadow-lg"
              style={`border-color: ${layerColors.workflow}; background: color-mix(in srgb, ${layerColors.workflow} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.workflow}`}
            >
              <div class="flex items-center justify-between gap-2">
                <span
                  class="font-mono font-semibold text-sm"
                  style={`color: ${layerColors.workflow}`}
                  >agentic-workflow</span
                >
                <span
                  class="size-2 rounded-full bg-green-400"
                  title="In Progress"></span>
              </div>
              <span class="text-xs text-gray">Workflow Definition System</span>
            </div>
          </div>
        </div>

        <!-- Legend -->
        <div class="flex items-center gap-5 flex-wrap">
          {
            Object.entries(layerColors).map(([role, color]) => (
              <span class="flex items-center gap-1.5 font-mono text-xs text-gray">
                <span
                  class="size-2 rounded-full"
                  style={`background: ${color}`}
                />
                {role}
              </span>
            ))
          }
          <span class="w-px h-4 bg-border/20"></span>
          <span class="flex items-center gap-1.5 font-mono text-xs text-gray">
            <span class="size-2 rounded-full bg-green-400"></span>in-progress
          </span>
          <span class="flex items-center gap-1.5 font-mono text-xs text-gray">
            <span class="size-2 rounded-full bg-amber-400 opacity-60"
            ></span>planned
          </span>
        </div>

        <p class="text-sm text-dark-gray italic max-w-xl leading-relaxed">
          specorator currently reads agentic-workflow methodology directly via
          Claude Code CLI. specorator-runtime will replace that CLI bridge in
          v2.0, and agentonomous's six specialized agent roles will power
          specorator's AI coworker features. A core requirement across all
          layers: agents must read from and write back to the same plain files
          the user works in — no separate state, no proprietary formats, no
          lock-in.
        </p>
      </div>
    </section>

    <!-- ─── 05 Projects ──────────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-3 max-w-3xl">
          <h2
            class="font-mono text-xs uppercase tracking-widest text-gray flex items-center gap-3"
          >
            <span class="text-dark-gray">05</span>Projects
          </h2>
          <p class="font-primary font-bold text-2xl text-text leading-snug">
            Every component, at a glance.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          {
            projects.map((p) => (
              <article
                class="bg-card/70 border border-border/6 rounded-3xl p-6 flex flex-col gap-4 group relative overflow-hidden transition-all duration-200 hover:bg-card/90"
                style={`border-top: 2px solid ${layerColors[p.role]}`}
              >
                <div class="flex flex-col gap-1">
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="font-mono font-semibold text-base text-text">
                      {p.name}
                    </h3>
                    {p.status && (
                      <span
                        class="font-mono text-[10px] font-bold uppercase tracking-wide border px-1.5 py-0.5 rounded flex-shrink-0"
                        style={`color: ${statusColors[p.status]}; border-color: ${statusColors[p.status]}`}
                      >
                        {statusLabels[p.status]}
                      </span>
                    )}
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-dark-gray">{p.layer}</span>
                    {p.version && (
                      <span
                        class="font-mono text-[10px] border px-1.5 py-0.5 rounded"
                        style={`color: ${layerColors[p.role]}; border-color: color-mix(in srgb, ${layerColors[p.role]} 30%, transparent)`}
                      >
                        {p.version}
                      </span>
                    )}
                  </div>
                </div>

                <p class="text-sm text-gray leading-relaxed flex-1">
                  {p.description}
                </p>

                {p.techStack && p.techStack.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {p.techStack.map((tech: string) => (
                      <span class="font-mono text-[10px] text-dark-gray bg-body border border-border/20 px-2 py-0.5 rounded">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}

                {(p.lastUpdate || p.openIssues !== null) && (
                  <div class="flex gap-5 pt-3 border-t border-border/10">
                    {p.lastUpdate && (
                      <div class="flex flex-col gap-0.5">
                        <span class="font-mono text-[9px] uppercase tracking-widest text-dark-gray">
                          Updated
                        </span>
                        <span class="font-mono text-xs text-gray">
                          {p.lastUpdate}
                        </span>
                      </div>
                    )}
                    {p.openIssues !== null && (
                      <div class="flex flex-col gap-0.5">
                        <span class="font-mono text-[9px] uppercase tracking-widest text-dark-gray">
                          Issues & PRs
                        </span>
                        <span class="font-mono text-xs text-gray">
                          {p.openIssues}
                        </span>
                      </div>
                    )}
                  </div>
                )}

                <div class="flex gap-3">
                  {p.repo && (
                    <a
                      href={p.repo}
                      target="_blank"
                      rel="noopener"
                      class="font-mono text-xs text-primary/70 hover:text-primary transition-colors duration-150 no-underline hover:no-underline"
                    >
                      Repo ↗
                    </a>
                  )}
                  {p.docs && (
                    <a
                      href={p.docs}
                      target="_blank"
                      rel="noopener"
                      class="font-mono text-xs text-primary/70 hover:text-primary transition-colors duration-150 no-underline hover:no-underline"
                    >
                      Website ↗
                    </a>
                  )}
                  {p.prd && (
                    <a
                      href={p.prd}
                      target="_blank"
                      rel="noopener"
                      class="font-mono text-xs text-primary/70 hover:text-primary transition-colors duration-150 no-underline hover:no-underline"
                    >
                      PRD ↗
                    </a>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── 06 Roadmap ───────────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-3 max-w-3xl">
          <h2
            class="font-mono text-xs uppercase tracking-widest text-gray flex items-center gap-3"
          >
            <span class="text-dark-gray">06</span>Roadmap
          </h2>
          <p class="font-primary font-bold text-2xl text-text leading-snug">
            What's shipping next.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {
            roadmap.map((entry) => (
              <div
                class={`bg-card/70 rounded-3xl p-6 flex flex-col gap-3 ${
                  entry.milestoneStatus === "active"
                    ? "border border-primary/40"
                    : entry.milestoneStatus === "done"
                      ? "border border-border/6"
                      : "border border-border/6 opacity-45"
                }`}
                style={
                  entry.milestoneStatus === "active"
                    ? "background: color-mix(in srgb, #22d3ee 4%, #111113)"
                    : ""
                }
              >
                <div class="flex items-center justify-between gap-2">
                  <span
                    class={`font-mono text-xs font-bold uppercase tracking-widest ${entry.milestoneStatus === "done" ? "text-dark-gray" : "text-primary"}`}
                  >
                    {entry.phase}
                  </span>
                  {entry.milestoneStatus === "active" ? (
                    <span class="font-mono text-[10px] font-bold uppercase tracking-wide text-green-400 border border-green-400 px-1.5 py-0.5 rounded">
                      Active
                    </span>
                  ) : entry.milestoneStatus === "done" ? (
                    <span class="font-mono text-[10px] font-bold uppercase tracking-wide text-dark-gray border border-border/20 px-1.5 py-0.5 rounded">
                      Done
                    </span>
                  ) : (
                    <span class="font-mono text-[10px] font-bold uppercase tracking-wide text-amber-400 border border-amber-400 px-1.5 py-0.5 rounded">
                      Planned
                    </span>
                  )}
                </div>
                <span
                  class={`font-mono text-sm font-semibold ${entry.milestoneStatus === "done" ? "text-dark-gray" : "text-text"}`}
                >
                  {entry.title}
                </span>
                <span class="text-xs text-gray leading-relaxed">
                  {entry.description}
                </span>
                {entry.stats.total > 0 && (
                  <div class="flex flex-col gap-1.5 mt-1">
                    <div class="w-full h-1 rounded-full bg-border/20 overflow-hidden">
                      <div
                        class="h-full rounded-full bg-primary/60 transition-all"
                        style={`width: ${Math.round((entry.stats.done / entry.stats.total) * 100)}%`}
                      />
                    </div>
                    <span class="font-mono text-[10px] text-dark-gray">
                      {entry.stats.done}/{entry.stats.total} done
                      {entry.stats.inProgress > 0 &&
                        ` · ${entry.stats.inProgress} in progress`}
                    </span>
                  </div>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── Final CTA ────────────────────────────────────────────────── -->
    <section class="container-padding-x py-20">
      <div
        class="rounded-3xl border border-primary/20 p-10 flex flex-col gap-6 items-start"
        style="background: color-mix(in srgb, #22d3ee 3%, #111113)"
      >
        <div class="flex flex-col gap-3 max-w-2xl">
          <span class="font-mono text-xs uppercase tracking-widest text-primary"
            >Ready to start?</span
          >
          <p class="font-primary font-bold text-3xl text-text leading-snug">
            Stop reinventing your process.<br />
            <span class="text-primary">Start building with a system.</span>
          </p>
          <p class="text-gray text-base leading-relaxed">
            Install the Obsidian plugin, move through the 12 stages, and let the
            agents handle the drafting. No coding background needed. Everything
            is open source — no sign-up, no lock-in, your files stay yours.
          </p>
        </div>
        <div class="flex items-center gap-4 flex-wrap">
          <a
            href={specorator?.docs ??
              specorator?.repo ??
              "https://github.com/Luis85/specorator"}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 bg-primary text-body font-mono font-semibold text-sm px-6 py-3 rounded-xl hover:bg-primary/90 transition-colors duration-150 no-underline hover:no-underline"
          >
            Get specorator ↗
          </a>
          <a
            href={agenticWorkflow?.docs ??
              agenticWorkflow?.repo ??
              "https://github.com/Luis85/agentic-workflow"}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 border border-border/30 text-gray font-mono font-semibold text-sm px-6 py-3 rounded-xl hover:border-border/60 hover:text-text transition-colors duration-150 no-underline hover:no-underline"
          >
            Browse the workflow ↗
          </a>
        </div>
        <p class="font-mono text-xs text-dark-gray">
          All four projects are open source under the MIT licence. Active
          milestone: <span class="text-primary"
            >{activeMilestone.phase} — {activeMilestone.title}</span
          >
        </p>
      </div>
    </section>
  </MainContainer>
</Base>
