---
import Base from "@/layouts/Base.astro";
import MainContainer from "@/components/MainContainer.astro";
import projectsData from "@/data/projects.json";
import roadmapData from "@/data/roadmap.json";

const { projects } = projectsData;
const { milestones } = roadmapData;
const activeMilestone = milestones.find((m) => m.status === "active");

const layerColors: Record<string, string> = {
  ui: "#818cf8",
  runtime: "#22d3ee",
  agents: "#f472b6",
  workflow: "#fb923c",
};

const statusLabels: Record<string, string> = {
  "in-progress": "In Progress",
  planned: "Planned",
  done: "Done",
};

const statusColors: Record<string, string> = {
  "in-progress": "#22c55e",
  planned: "#f59e0b",
  done: "#3b82f6",
};

const inProgressCount = projects.filter(
  (p) => p.status === "in-progress",
).length;
const plannedCount = projects.filter((p) => p.status === "planned").length;
---

<Base
  title="Specorator Hub — Ecosystem Entry Point"
  description="The hub and entry point for the Specorator ecosystem — navigate projects, explore the architecture, and track progress across all components."
>
  <MainContainer>
    <!-- ─── Hero / Header ────────────────────────────────────────────── -->
    <section class="container-padding-x pt-20 pb-10 border-b border-border/10">
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-gray uppercase tracking-widest"
            >ecosystem hub</span
          >
          <span
            class="inline-flex items-center gap-1.5 font-mono text-xs text-green-400"
          >
            <span class="size-1.5 rounded-full bg-green-400 animate-pulse"
            ></span>live
          </span>
        </div>
        <h1
          class="font-primary font-bold text-5xl md:text-6xl text-text tracking-tight"
        >
          specorator<span class="text-primary">://hub</span>
        </h1>
        <p class="text-gray text-lg max-w-2xl leading-relaxed">
          Four-component system for spec-driven, agentic software development —
          where humans define what to build and specialist agents handle how.
          One URL to understand the system, see what is active, and navigate to
          any component.
        </p>
        <div class="flex items-center gap-6 pt-2 flex-wrap">
          <div class="flex flex-col gap-1">
            <span class="font-mono font-bold text-3xl text-text">4</span>
            <span class="font-mono text-xs uppercase tracking-wide text-gray"
              >Components</span
            >
          </div>
          <div class="w-px h-8 bg-border/20"></div>
          <div class="flex flex-col gap-1">
            <span class="font-mono font-bold text-3xl text-green-400"
              >{inProgressCount}</span
            >
            <span class="font-mono text-xs uppercase tracking-wide text-gray"
              >In Progress</span
            >
          </div>
          <div class="w-px h-8 bg-border/20"></div>
          <div class="flex flex-col gap-1">
            <span class="font-mono font-bold text-3xl text-amber-400"
              >{plannedCount}</span
            >
            <span class="font-mono text-xs uppercase tracking-wide text-gray"
              >Planned</span
            >
          </div>
          <div class="w-px h-8 bg-border/20"></div>
          <div class="flex flex-col gap-1">
            <span class="font-mono font-bold text-3xl text-primary"
              >{activeMilestone?.phase ?? "—"}</span
            >
            <span class="font-mono text-xs uppercase tracking-wide text-gray"
              >Active Milestone</span
            >
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 02 Architecture ──────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <h2
        class="font-mono text-xs uppercase tracking-widest text-gray mb-10 flex items-center gap-3"
      >
        <span class="text-dark-gray">02</span>Architecture
      </h2>

      <div class="flex flex-col items-center max-w-xl gap-0">
        <!-- Row 1: specorator -->
        <div
          class="w-full rounded-2xl border p-4 flex flex-col gap-1 transition-shadow duration-200 hover:shadow-lg"
          style={`border-color: ${layerColors.ui}; background: color-mix(in srgb, ${layerColors.ui} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.ui}`}
        >
          <div class="flex items-center justify-between gap-2">
            <span
              class="font-mono font-semibold text-sm"
              style={`color: ${layerColors.ui}`}>specorator</span
            >
            <span class="size-2 rounded-full bg-green-400" title="In Progress"
            ></span>
          </div>
          <span class="text-xs text-gray"
            >UI / Visualization Layer · Obsidian Plugin</span
          >
        </div>

        <!-- Connector + label -->
        <div class="flex flex-col items-center py-1 gap-0.5">
          <span class="font-mono text-[10px] text-dark-gray"
            >spec methodology</span
          >
          <div class="w-px h-4 bg-border/30"></div>
          <span class="text-dark-gray text-[8px]">▼</span>
        </div>

        <!-- Row 2: specorator-runtime -->
        <div
          class="w-full rounded-2xl border border-dashed p-4 flex flex-col gap-1 opacity-70 transition-shadow duration-200 hover:shadow-lg"
          style={`border-color: ${layerColors.runtime}; background: color-mix(in srgb, ${layerColors.runtime} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.runtime}`}
        >
          <div class="flex items-center justify-between gap-2">
            <span
              class="font-mono font-semibold text-sm"
              style={`color: ${layerColors.runtime}`}>specorator-runtime</span
            >
            <span
              class="font-mono text-[9px] font-bold uppercase tracking-wide text-amber-400 border border-amber-400 px-1.5 py-0.5 rounded"
              >planned</span
            >
          </div>
          <span class="text-xs text-gray"
            >Execution Runtime · Orchestration Bridge</span
          >
        </div>

        <!-- Split connector -->
        <div class="flex justify-around w-full max-w-xl px-16 py-1">
          <div class="flex flex-col items-center gap-0.5">
            <div class="w-px h-4 bg-border/30"></div>
            <span class="text-dark-gray text-[8px]">▼</span>
          </div>
          <div class="flex flex-col items-center gap-0.5">
            <div class="w-px h-4 bg-border/30"></div>
            <span class="text-dark-gray text-[8px]">▼</span>
          </div>
        </div>

        <!-- Row 3: agentonomous + agentic-workflow -->
        <div class="w-full grid grid-cols-2 gap-4">
          <div
            class="rounded-2xl border border-dashed p-4 flex flex-col gap-1 opacity-70 transition-shadow duration-200 hover:shadow-lg"
            style={`border-color: ${layerColors.agents}; background: color-mix(in srgb, ${layerColors.agents} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.agents}`}
          >
            <div class="flex items-center justify-between gap-2">
              <span
                class="font-mono font-semibold text-sm"
                style={`color: ${layerColors.agents}`}>agentonomous</span
              >
              <span
                class="font-mono text-[9px] font-bold uppercase tracking-wide text-amber-400 border border-amber-400 px-1.5 py-0.5 rounded"
                >planned</span
              >
            </div>
            <span class="text-xs text-gray">Agent Library</span>
          </div>

          <div
            class="rounded-2xl border p-4 flex flex-col gap-1 transition-shadow duration-200 hover:shadow-lg"
            style={`border-color: ${layerColors.workflow}; background: color-mix(in srgb, ${layerColors.workflow} 6%, #111113); box-shadow: 0 0 24px -10px ${layerColors.workflow}`}
          >
            <div class="flex items-center justify-between gap-2">
              <span
                class="font-mono font-semibold text-sm"
                style={`color: ${layerColors.workflow}`}>agentic-workflow</span
              >
              <span class="size-2 rounded-full bg-green-400" title="In Progress"
              ></span>
            </div>
            <span class="text-xs text-gray">Workflow Definition System</span>
          </div>
        </div>
      </div>

      <!-- Legend -->
      <div class="flex items-center gap-5 mt-8 flex-wrap">
        {
          Object.entries(layerColors).map(([role, color]) => (
            <span class="flex items-center gap-1.5 font-mono text-xs text-gray">
              <span
                class="size-2 rounded-full"
                style={`background: ${color}`}
              />
              {role}
            </span>
          ))
        }
        <span class="w-px h-4 bg-border/20"></span>
        <span class="flex items-center gap-1.5 font-mono text-xs text-gray">
          <span class="size-2 rounded-full bg-green-400"></span>in-progress
        </span>
        <span class="flex items-center gap-1.5 font-mono text-xs text-gray">
          <span class="size-2 rounded-full bg-amber-400 opacity-60"
          ></span>planned
        </span>
      </div>

      <p class="mt-5 text-sm text-dark-gray italic max-w-xl leading-relaxed">
        specorator currently reads agentic-workflow methodology directly.
        specorator-runtime will become the orchestration bridge once
        implemented, and agentonomous will power agentic coworker features in
        specorator v2.0.
      </p>
    </section>

    <!-- ─── 03 Projects ──────────────────────────────────────────────── -->
    <section class="container-padding-x py-16 border-b border-border/10">
      <h2
        class="font-mono text-xs uppercase tracking-widest text-gray mb-10 flex items-center gap-3"
      >
        <span class="text-dark-gray">03</span>Projects
      </h2>

      <div class="grid md:grid-cols-2 gap-4">
        {
          projects.map((p) => (
            <article
              class="bg-card/70 border border-border/6 rounded-3xl p-6 flex flex-col gap-4 group relative overflow-hidden transition-all duration-200 hover:bg-card/90"
              style={`border-top: 2px solid ${layerColors[p.role]}`}
            >
              <div class="flex flex-col gap-1">
                <div class="flex items-center justify-between gap-2">
                  <h3 class="font-mono font-semibold text-base text-text">
                    {p.name}
                  </h3>
                  <span
                    class="font-mono text-[10px] font-bold uppercase tracking-wide border px-1.5 py-0.5 rounded flex-shrink-0"
                    style={`color: ${statusColors[p.status]}; border-color: ${statusColors[p.status]}`}
                  >
                    {statusLabels[p.status]}
                  </span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-xs text-dark-gray">{p.layer}</span>
                  {p.version && (
                    <span
                      class="font-mono text-[10px] border px-1.5 py-0.5 rounded"
                      style={`color: ${layerColors[p.role]}; border-color: color-mix(in srgb, ${layerColors[p.role]} 30%, transparent)`}
                    >
                      {p.version}
                    </span>
                  )}
                </div>
              </div>

              <p class="text-sm text-gray leading-relaxed flex-1">
                {p.description}
              </p>

              {p.techStack && p.techStack.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {p.techStack.map((tech: string) => (
                    <span class="font-mono text-[10px] text-dark-gray bg-body border border-border/20 px-2 py-0.5 rounded">
                      {tech}
                    </span>
                  ))}
                </div>
              )}

              {(p.lastUpdate || p.openIssues !== null) && (
                <div class="flex gap-5 pt-3 border-t border-border/10">
                  {p.lastUpdate && (
                    <div class="flex flex-col gap-0.5">
                      <span class="font-mono text-[9px] uppercase tracking-widest text-dark-gray">
                        Updated
                      </span>
                      <span class="font-mono text-xs text-gray">
                        {p.lastUpdate}
                      </span>
                    </div>
                  )}
                  {p.openIssues !== null && (
                    <div class="flex flex-col gap-0.5">
                      <span class="font-mono text-[9px] uppercase tracking-widest text-dark-gray">
                        Open Issues
                      </span>
                      <span class="font-mono text-xs text-gray">
                        {p.openIssues}
                      </span>
                    </div>
                  )}
                </div>
              )}

              <div class="flex gap-3">
                {p.repo && (
                  <a
                    href={p.repo}
                    target="_blank"
                    rel="noopener"
                    class="font-mono text-xs text-primary/70 hover:text-primary transition-colors duration-150 no-underline hover:no-underline"
                  >
                    Repo ↗
                  </a>
                )}
                {p.docs && (
                  <a
                    href={p.docs}
                    target="_blank"
                    rel="noopener"
                    class="font-mono text-xs text-primary/70 hover:text-primary transition-colors duration-150 no-underline hover:no-underline"
                  >
                    Docs ↗
                  </a>
                )}
                {p.prd && (
                  <a
                    href={p.prd}
                    target="_blank"
                    rel="noopener"
                    class="font-mono text-xs text-primary/70 hover:text-primary transition-colors duration-150 no-underline hover:no-underline"
                  >
                    PRD ↗
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ─── 04 Roadmap ───────────────────────────────────────────────── -->
    <section class="container-padding-x py-16">
      <h2
        class="font-mono text-xs uppercase tracking-widest text-gray mb-10 flex items-center gap-3"
      >
        <span class="text-dark-gray">04</span>Roadmap
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {
          milestones.map((m) => (
            <div
              class={`bg-card/70 rounded-3xl p-6 flex flex-col gap-3 ${m.status === "active" ? "border border-primary/40" : "border border-border/6 opacity-45"}`}
              style={
                m.status === "active"
                  ? "background: color-mix(in srgb, #22d3ee 4%, #111113)"
                  : ""
              }
            >
              <div class="flex items-center justify-between gap-2">
                <span class="font-mono text-xs font-bold uppercase tracking-widest text-primary">
                  {m.phase}
                </span>
                {m.status === "active" ? (
                  <span class="font-mono text-[10px] font-bold uppercase tracking-wide text-green-400 border border-green-400 px-1.5 py-0.5 rounded">
                    Active
                  </span>
                ) : (
                  <span class="font-mono text-[10px] font-bold uppercase tracking-wide text-amber-400 border border-amber-400 px-1.5 py-0.5 rounded">
                    Planned
                  </span>
                )}
              </div>
              <span class="font-mono text-sm font-semibold text-text">
                {m.title}
              </span>
              <span
                class="text-xs text-gray leading-relaxed"
                set:html={m.description}
              />
            </div>
          ))
        }
      </div>
    </section>
  </MainContainer>
</Base>
