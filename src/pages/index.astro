---
import Layout from '../layouts/Layout.astro';
import projectsData from '../data/projects.json';

const { projects } = projectsData;

const layerColors: Record<string, string> = {
  ui:       'var(--layer-ui)',
  runtime:  'var(--layer-runtime)',
  agents:   'var(--layer-agents)',
  workflow: 'var(--layer-workflow)',
};

const statusLabels: Record<string, string> = {
  'in-progress': 'In Progress',
  'planned':     'Planned',
  'done':        'Done',
};

const statusColors: Record<string, string> = {
  'in-progress': 'var(--status-in-progress)',
  'planned':     'var(--status-planned)',
  'done':        'var(--status-done)',
};

const archLayers = [
  { id: 'specorator',        label: 'specorator',        sub: 'UI / Visualization Layer', color: 'var(--layer-ui)',       wide: true,  row: 1 },
  { id: 'specorator-runtime',label: 'specorator-runtime',sub: 'Execution Runtime',         color: 'var(--layer-runtime)', wide: true,  row: 2 },
  { id: 'agentonomous',      label: 'agentonomous',      sub: 'Agent Library',             color: 'var(--layer-agents)',  wide: false, row: 3 },
  { id: 'agentic-workflow',  label: 'agentic-workflow',  sub: 'Workflow Definition',        color: 'var(--layer-workflow)',wide: false, row: 3 },
];
---

<Layout title="Specorator Hub">

  <!-- ─── Header ─────────────────────────────────────────────────── -->
  <header class="header">
    <div class="container header-inner">
      <div>
        <h1 class="logo">specorator<span class="logo-accent">://hub</span></h1>
        <p class="tagline">Ecosystem Control Plane &middot; V1</p>
      </div>
      <div class="header-meta">
        <span class="version-badge">v0.1.0</span>
        <span class="status-indicator">
          <span class="pulse"></span>live
        </span>
      </div>
    </div>
  </header>

  <main>
    <div class="container">

      <!-- ─── 01 Architecture ──────────────────────────────────────── -->
      <section class="section">
        <h2 class="section-title"><span class="section-num">01</span>Architecture</h2>

        <div class="arch-wrap">
          <!-- Row 1: UI -->
          <div class="arch-row">
            <div class="arch-node" style={`--c: var(--layer-ui)`}>
              <span class="arch-name">specorator</span>
              <span class="arch-sub">UI / Visualization Layer</span>
            </div>
          </div>

          <div class="arch-connector arch-connector--single">
            <span class="arch-line"></span>
            <span class="arch-arrow-head">▼</span>
          </div>

          <!-- Row 2: Runtime -->
          <div class="arch-row">
            <div class="arch-node" style={`--c: var(--layer-runtime)`}>
              <span class="arch-name">specorator-runtime</span>
              <span class="arch-sub">Execution Runtime</span>
            </div>
          </div>

          <div class="arch-connector arch-connector--split">
            <div class="arch-split-line">
              <span class="arch-line"></span>
              <span class="arch-arrow-head">▼</span>
            </div>
            <div class="arch-split-line">
              <span class="arch-line"></span>
              <span class="arch-arrow-head">▼</span>
            </div>
          </div>

          <!-- Row 3: Agents + Workflow -->
          <div class="arch-row arch-row--split">
            <div class="arch-node" style={`--c: var(--layer-agents)`}>
              <span class="arch-name">agentonomous</span>
              <span class="arch-sub">Agent Library</span>
            </div>
            <div class="arch-node" style={`--c: var(--layer-workflow)`}>
              <span class="arch-name">agentic-workflow</span>
              <span class="arch-sub">Workflow Definition</span>
            </div>
          </div>
        </div>

        <div class="arch-legend">
          {Object.entries(layerColors).map(([role, color]) => (
            <span class="legend-item" style={`--c: ${color}`}>
              <span class="legend-dot"></span>
              {role}
            </span>
          ))}
        </div>
      </section>

      <!-- ─── 02 Projects ──────────────────────────────────────────── -->
      <section class="section">
        <h2 class="section-title"><span class="section-num">02</span>Projects</h2>

        <div class="projects-grid">
          {projects.map((p) => (
            <article class="card" style={`--ca: ${layerColors[p.role]}`}>
              <div class="card-header">
                <div class="card-title-row">
                  <h3 class="card-name">{p.name}</h3>
                  <span class="status-badge" style={`--sc: ${statusColors[p.status]}`}>
                    {statusLabels[p.status]}
                  </span>
                </div>
                <span class="card-layer">{p.layer}</span>
              </div>

              <p class="card-desc">{p.description}</p>

              {(p.lastUpdate || p.openIssues !== null) && (
                <div class="card-meta">
                  {p.lastUpdate && (
                    <span class="meta-item">
                      <span class="meta-label">Updated</span>
                      <span class="meta-value mono">{p.lastUpdate}</span>
                    </span>
                  )}
                  {p.openIssues !== null && (
                    <span class="meta-item">
                      <span class="meta-label">Issues</span>
                      <span class="meta-value mono">{p.openIssues}</span>
                    </span>
                  )}
                </div>
              )}

              <div class="card-links">
                {p.repo  && <a href={p.repo}  target="_blank" rel="noopener" class="card-link">Repo ↗</a>}
                {p.docs  && <a href={p.docs}  target="_blank" rel="noopener" class="card-link">Docs ↗</a>}
                {p.prd   && <a href={p.prd}   target="_blank" rel="noopener" class="card-link">PRD ↗</a>}
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- ─── 03 Roadmap ───────────────────────────────────────────── -->
      <section class="section">
        <h2 class="section-title"><span class="section-num">03</span>Roadmap</h2>

        <div class="roadmap-grid">
          <div class="roadmap-card roadmap-card--active">
            <span class="roadmap-phase">V1</span>
            <span class="roadmap-desc">Static hub · project listing · architecture overview</span>
          </div>
          <div class="roadmap-card">
            <span class="roadmap-phase">V2</span>
            <span class="roadmap-desc">JSON-driven data · GitHub API status integration</span>
          </div>
          <div class="roadmap-card">
            <span class="roadmap-phase">V3</span>
            <span class="roadmap-desc">Runtime observability · event stream visualization</span>
          </div>
          <div class="roadmap-card">
            <span class="roadmap-phase">V4</span>
            <span class="roadmap-desc">Workflow execution tracking · knowledge graph</span>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-text mono">
        specorator-ecosystem &middot;
        <a href="https://github.com/luis85/specorator-ecosystem">github.com/luis85/specorator-ecosystem</a>
      </span>
    </div>
  </footer>

</Layout>

<style>
  /* ── Header ─────────────────────────────────────────────────────── */
  .header {
    border-bottom: 1px solid var(--border);
    padding: 24px 0;
    background: linear-gradient(to bottom, rgba(34,211,238,0.04), transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .logo-accent { color: var(--accent); }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .version-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 20px;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--status-in-progress);
  }

  .pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--status-in-progress);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  /* ── Sections ────────────────────────────────────────────────────── */
  .section {
    padding: 56px 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .section:last-child { border-bottom: none; }

  .section-title {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    margin-bottom: 36px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  /* ── Architecture ────────────────────────────────────────────────── */
  .arch-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 600px;
  }

  .arch-row {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .arch-row--split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .arch-node {
    flex: 1;
    border: 1px solid var(--c);
    border-radius: var(--radius);
    padding: 14px 20px;
    background: color-mix(in srgb, var(--c) 6%, var(--bg-card));
    box-shadow: 0 0 24px -10px var(--c);
    display: flex;
    flex-direction: column;
    gap: 3px;
    transition: box-shadow 0.2s;
  }

  .arch-node:hover {
    box-shadow: 0 0 36px -6px var(--c);
  }

  .arch-name {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c);
  }

  .arch-sub {
    font-size: 0.72rem;
    color: var(--text-secondary);
  }

  .arch-connector--single {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4px 0;
  }

  .arch-connector--split {
    display: flex;
    justify-content: space-around;
    width: 100%;
    max-width: 600px;
    padding: 4px 60px;
  }

  .arch-split-line {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .arch-line {
    display: block;
    width: 1px;
    height: 14px;
    background: var(--border);
  }

  .arch-arrow-head {
    font-size: 0.6rem;
    color: var(--text-muted);
    line-height: 1;
  }

  .arch-legend {
    display: flex;
    gap: 20px;
    margin-top: 24px;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-secondary);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c);
  }

  /* ── Project Cards ───────────────────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: 2px solid var(--ca);
    border-radius: var(--radius);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.15s, border-color 0.15s;
  }

  .card:hover {
    background: var(--bg-card-hover);
    border-color: var(--ca);
    border-top-color: var(--ca);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .card-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .card-name {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sc);
    border: 1px solid var(--sc);
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
    opacity: 0.9;
  }

  .card-layer {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.55;
    flex: 1;
  }

  .card-meta {
    display: flex;
    gap: 20px;
    padding-top: 10px;
    border-top: 1px solid var(--border-subtle);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .meta-label {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .meta-value {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .mono { font-family: var(--font-mono); }

  .card-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .card-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    opacity: 0.75;
    transition: opacity 0.15s;
  }

  .card-link:hover {
    opacity: 1;
    text-decoration: none;
  }

  /* ── Roadmap ─────────────────────────────────────────────────────── */
  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }

  .roadmap-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    opacity: 0.45;
  }

  .roadmap-card--active {
    opacity: 1;
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 4%, var(--bg-card));
  }

  .roadmap-phase {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .roadmap-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ── Footer ──────────────────────────────────────────────────────── */
  .footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
  }

  .footer-text {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .header-inner { flex-direction: column; align-items: flex-start; }
    .arch-row--split { grid-template-columns: 1fr; }
    .arch-connector--split { padding: 4px 40px; }
  }
</style>
